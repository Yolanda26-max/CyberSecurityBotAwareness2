<Window x:Class="CyberSecurityBotAwareness.TaskManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Task Manager" Height="650" Width="750"
        Background="#1A1A2E" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Padding="18,12" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📋  Cybersecurity Task Manager"
                           FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                           Foreground="#E91E8C"/>
                <TextBlock Text="Manage your cybersecurity tasks and reminders"
                           FontFamily="Segoe UI" FontSize="11" Foreground="#8B8BA7"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ADD TASK FORM -->
        <Border Grid.Row="1" Background="#16213E" CornerRadius="10" Padding="18" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Add New Task" FontFamily="Segoe UI" FontSize="14"
                           FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,10">
                        <TextBlock Text="Task Title *" Foreground="#8B8BA7"
                                   FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TitleBox"
                                 Background="#0F3460" Foreground="#FFFFFF"
                                 BorderBrush="#E91E8C" BorderThickness="1"
                                 FontFamily="Segoe UI" FontSize="12"
                                 Padding="8,6" CaretBrush="#E91E8C"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,10">
                        <TextBlock Text="Description" Foreground="#8B8BA7"
                                   FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="DescriptionBox"
                                 Background="#0F3460" Foreground="#FFFFFF"
                                 BorderBrush="#333366" BorderThickness="1"
                                 FontFamily="Segoe UI" FontSize="12"
                                 Padding="8,6" CaretBrush="#E91E8C"/>
                    </StackPanel>

                    <!-- Reminder checkbox -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,10"
                                Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ReminderCheckBox"
                                  Foreground="#FFFFFF" FontFamily="Segoe UI"
                                  Content="Set a reminder?" FontSize="12"
                                  Checked="ReminderCheckBox_Checked"
                                  Unchecked="ReminderCheckBox_Unchecked"/>
                    </StackPanel>

                    <!-- Reminder date -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,10"
                                x:Name="ReminderPanel" Visibility="Collapsed">
                        <TextBlock Text="Reminder Date" Foreground="#8B8BA7"
                                   FontFamily="Segoe UI" FontSize="11" Margin="0,0,0,4"/>
                        <DatePicker x:Name="ReminderDatePicker"
                                    FontFamily="Segoe UI" FontSize="12"/>
                    </StackPanel>

                    <!-- Add Button -->
                    <Button Grid.Row="2" Grid.ColumnSpan="2"
                            Content="➕  Add Task"
                            Background="#E91E8C" Foreground="White"
                            FontFamily="Segoe UI" FontWeight="SemiBold"
                            FontSize="13" Padding="20,10"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Left"
                            Click="AddTaskButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Form status -->
                    <TextBlock x:Name="FormStatus" Grid.Row="3" Grid.ColumnSpan="2"
                               Text="" Foreground="#00FF41"
                               FontFamily="Segoe UI" FontSize="11" Margin="0,8,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- TASK LIST -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="10" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Your Tasks"
                           FontFamily="Segoe UI" FontSize="14"
                           FontWeight="SemiBold" Foreground="#FFFFFF" Margin="0,0,0,10"/>
                <ListView x:Name="TaskListView" Grid.Row="1"
                          Background="Transparent" BorderThickness="0"
                          Foreground="#FFFFFF" FontFamily="Segoe UI"
                          FontSize="12" SelectionMode="Single">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Title" Width="160" DisplayMemberBinding="{Binding Title}"/>
                            <GridViewColumn Header="Description" Width="180" DisplayMemberBinding="{Binding Description}"/>
                            <GridViewColumn Header="Reminder" Width="110" DisplayMemberBinding="{Binding ReminderDisplay}"/>
                            <GridViewColumn Header="Status" Width="90" DisplayMemberBinding="{Binding Status}"/>
                        </GridView>
                    </ListView.View>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#C9D1D9"/>
                            <Setter Property="Padding" Value="4"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#0F3460"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>
        </Border>

        <!-- ACTION BUTTONS -->
        <Border Grid.Row="3" Background="#16213E" CornerRadius="10"
                Padding="12" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <Button Content="✅  Mark Complete"
                        Background="#238636" Foreground="White"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        FontSize="12" Padding="16,8" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0"
                        Click="MarkCompleteButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="🗑️  Delete Task"
                        Background="#DA3633" Foreground="White"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        FontSize="12" Padding="16,8" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0"
                        Click="DeleteTaskButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="🔄  Refresh"
                        Background="#0D47A1" Foreground="White"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        FontSize="12" Padding="16,8" BorderThickness="0"
                        Cursor="Hand" Click="RefreshButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock x:Name="ActionStatus" Text=""
                           Foreground="#E91E8C" FontFamily="Segoe UI"
                           FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>