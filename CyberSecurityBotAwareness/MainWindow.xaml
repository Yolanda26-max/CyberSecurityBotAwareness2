<Window x:Class="CyberSecurityBotAwareness.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Guardian Bot" Height="650" Width="850"
        Background="#0D1117" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER / ASCII ART AREA -->
        <Border Grid.Row="0" Background="#161B22" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🛡️  CYBERSECURITY GUARDIAN BOT  🛡️"
                           FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                           Foreground="#00FF41" HorizontalAlignment="Center"/>
                <TextBlock Text="[ Protecting You in the Digital World ]"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- CHAT DISPLAY -->
        <Border Grid.Row="1" Background="#161B22" CornerRadius="8" Margin="0,0,0,10">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Padding="10">
                <RichTextBox x:Name="ChatDisplay"
                             Background="Transparent" BorderThickness="0"
                             IsReadOnly="True" FontFamily="Consolas" FontSize="13"
                             Foreground="#C9D1D9" VerticalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <!-- INPUT AREA -->
        <Border Grid.Row="2" Background="#161B22" CornerRadius="8" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputBox"
                         Grid.Column="0"
                         Background="#0D1117" Foreground="#C9D1D9"
                         BorderBrush="#30363D" BorderThickness="1"
                         FontFamily="Consolas" FontSize="13"
                         Padding="8" CaretBrush="White"
                         VerticalContentAlignment="Center"
                         KeyDown="UserInputBox_KeyDown"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send 🚀" Margin="8,0,0,0"
                        Background="#238636" Foreground="White"
                        FontWeight="Bold" Padding="14,8"
                        BorderThickness="0" Cursor="Hand"
                        Click="SendButton_Click"/>

                <Button x:Name="ClearButton"
                        Grid.Column="2"
                        Content="Clear 🗑️" Margin="8,0,0,0"
                        Background="#DA3633" Foreground="White"
                        FontWeight="Bold" Padding="14,8"
                        BorderThickness="0" Cursor="Hand"
                        Click="ClearButton_Click"/>
            </Grid>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#161B22" CornerRadius="8" Padding="8,5">
            <TextBlock x:Name="StatusBar"
                       Text="🟢 Bot is ready. Type a message to begin."
                       FontFamily="Consolas" FontSize="11"
                       Foreground="#8B949E"/>
        </Border>
    </Grid>
</Window>